// Regression: native pointwise Conv1D per-channel bias under NSS-only
// compilation (--torq-disable-host --torq-disable-css). Extracted from the real
// NNNR3 model (NNNR3_0079_0.0960_torq_bf16, layer Conv_55): 48->48 channels,
// kernel width 1, stride 1, per-channel bias, bf16. Same conv1d -> reduce_sum ->
// bias add path; verifies the bias is folded into the reduce on NSS.
#map = affine_map<(d0) -> (d0)>
#map1 = affine_map<(d0, d1, d2) -> (d0, d1, d2)>
module {
  func.func @main(%arg0: tensor<1x48x32xbf16>) -> tensor<1x48x32xbf16> {
      %cst = arith.constant dense<[-2.828130e+00, -3.984380e-01, 2.060550e-01, -4.433590e-01, -9.804680e-01, 1.206050e-01, -1.279300e-01, -1.164060e+00, -1.023440e+00, 5.039060e-01, -6.210940e-01, 8.398430e-02, -4.003910e-01, 1.206050e-01, -4.160160e-01, -1.875000e-01, -9.804680e-01, -1.570310e+00, 3.339840e-01, 2.441410e-01, 9.130850e-02, 5.781250e-01, 1.726560e+00, -7.275390e-02, 2.236330e-01, -2.531250e+00, -1.710940e+00, -6.445310e-01, 1.000000e+00, -1.976560e+00, -2.060550e-01, 2.656250e-01, -9.921870e-01, -1.460940e+00, -5.781250e-01, -2.031250e-01, -8.671870e-01, 5.546880e-01, -1.648440e+00, 1.343750e+00, -1.765630e+00, 9.882810e-01, -2.203130e+00, -4.648440e-01, -2.021480e-01, -6.494140e-02, 3.261720e-01, 3.750000e-01]> : tensor<48xbf16>
      %cst_0 = arith.constant dense<""> : tensor<48x48x1xbf16>
      %1 = tensor.empty() : tensor<1x48x32xf32>
      %2 = tensor.empty() : tensor<48xf32>
      %3 = linalg.generic {indexing_maps = [#map, #map], iterator_types = ["parallel"]} ins(%cst : tensor<48xbf16>) outs(%2 : tensor<48xf32>) {
      ^bb0(%in: bf16, %out: f32):
        %9 = arith.extf %in : bf16 to f32
        linalg.yield %9 : f32
      } -> tensor<48xf32>
      %broadcasted = linalg.broadcast ins(%3 : tensor<48xf32>) outs(%1 : tensor<1x48x32xf32>) dimensions = [0, 2] 
      %4 = linalg.conv_1d_ncw_fcw {dilations = dense<1> : vector<1xi64>, strides = dense<1> : vector<1xi64>} ins(%arg0, %cst_0 : tensor<1x48x32xbf16>, tensor<48x48x1xbf16>) outs(%broadcasted : tensor<1x48x32xf32>) -> tensor<1x48x32xf32>
      %5 = tensor.empty() : tensor<1x48x32xbf16>
      %6 = linalg.generic {indexing_maps = [#map1, #map1], iterator_types = ["parallel", "parallel", "parallel"]} ins(%4 : tensor<1x48x32xf32>) outs(%5 : tensor<1x48x32xbf16>) {
      ^bb0(%in: f32, %out: bf16):
        %9 = arith.truncf %in : f32 to bf16
        linalg.yield %9 : bf16
      } -> tensor<1x48x32xbf16>
    return %6 : tensor<1x48x32xbf16>
  }
}
